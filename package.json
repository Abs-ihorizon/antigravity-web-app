{
  "name": "receipt-detail-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "electron:dev": "set NODE_ENV=development&& electron .",
    "dev:all": "concurrently \"npm run dev\" \"npm run electron:dev\"",
    "build": "vite build",
    "build:electron": "vite build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.1",
    "vite-plugin-pwa": "^1.2.0"
  },
  "build": {
    "appId": "com.digitalledger.app",
    "productName": "Digital Ledger",
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": ["nsis"]
    },
    "files": [
      "dist/**/*",
      "electron/main.cjs"
    ]
  }
}
